# =====================================================================
# EcoMonitor (Node) - Variables de entorno
# Copia este archivo a ".env" y rellena los valores reales de Azure
# IMPORTANTE: NO subir el archivo .env a git
# =====================================================================

# Connection String del dispositivo "PC 1" (Azure IoT Hub -> Devices -> pc-sim-001)
DEVICE_1_CONNECTION_STRING=HostName=YOUR_HUB.azure-devices.net;DeviceId=pc-sim-001;SharedAccessKey=YOUR_KEY_1

# Connection String del dispositivo "PC 2"
DEVICE_2_CONNECTION_STRING=HostName=YOUR_HUB.azure-devices.net;DeviceId=pc-sim-002;SharedAccessKey=YOUR_KEY_2

# Puerto del servidor web (por defecto 5000). Se mantiene FLASK_PORT por compatibilidad.
FLASK_PORT=5000

# Intervalo de envio en segundos (por defecto 30)
SEND_INTERVAL_SECONDS=30
